{
  "name": "kivode-plus",
  "version": "1.1.0",
  "description": "Kivode+ Desktop - Secure AI-Assisted Code Workspace",
  "main": "dist/main/main.js",
  "author": "Kivode+",
  "license": "Kivode-Community-NCL-1.0",
  "private": false,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "dev:main": "tsc -p src/main/tsconfig.json && electron dist/main/main.js --dev",
    "dev:renderer": "vite",
    "build": "npm run clean && npm run build:main && npm run build:renderer && npm run remove-source-maps",
    "build:main": "tsc -p src/main/tsconfig.json --outDir dist/main",
    "build:renderer": "vite build",
    "clean": "rimraf dist release",
    "remove-source-maps": "rimraf dist/**/*.map 2>nul || echo No maps to remove",
    "build:win": "npm run build && electron-builder --win --publish=never",
    "build:win:portable": "npm run build && electron-builder --win portable --publish=never",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "electron-builder install-app-deps",
    "verify:sandbox-assets": "node scripts/verify-sandbox-assets.mjs",
    "verify:sandbox-assets:win32-x64": "node scripts/verify-sandbox-assets.mjs --platform=win32-x64",
    "build:release": "npm run verify:sandbox-assets && npm run build",
    "security:check": "node scripts/security-checks.mjs",
    "verify:baseline": "bash scripts/verify-baseline.sh",
    "test": "npm run security:check",
    "build:windows": "npm run build && electron-builder --win --publish=never",
    "build:mac": "npm run build && electron-builder --mac --publish=never",
    "build:linux": "npm run build && electron-builder --linux --publish=never",
    "build:all": "npm run build && electron-builder -mwl --publish=never"
  },
  "build": {
    "appId": "com.kivode.plus",
    "productName": "Kivode+",
    "copyright": "Copyright © 2024 Kivode+. All rights reserved.",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!dist/main/**/*.js.map",
      "!dist/renderer/**/*.js.map"
    ],
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "removePackageScripts": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Kivode+",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kivode+",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": false,
      "artifactName": "Kivode-Plus-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Kivode-Plus-Portable-${version}.exe"
    },
    "extraResources": [
      {
        "from": "src/main/python",
        "to": "python",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/diff": "^5.0.9",
    "@types/node": "^20.19.33",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^40.3.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.0",
    "terser": "^5.24.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.13",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@uiw/react-codemirror": "^4.25.4",
    "adm-zip": "^0.5.10",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "diff": "^5.1.0",
    "electron-store": "^8.2.0",
    "extract-zip": "^2.0.1",
    "framer-motion": "^10.16.16",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "prettier": "^3.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hotkeys-hook": "^4.4.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^1.0.5",
    "react-router-dom": "^6.21.0",
    "react-syntax-highlighter": "^15.5.1",
    "recharts": "^2.10.3",
    "remark-gfm": "^4.0.0",
    "simple-git": "^3.30.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  }
}
